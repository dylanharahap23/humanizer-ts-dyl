```gitignore
# Dependencies
node_modules/

# Build outputs
dist/
build/
target/

# TypeScript
*.tsbuildinfo
*.js.map

# Logs
*.log

# Environment variables
.env
.env.local
*.env.*

# IDE files
.vscode/
.idea/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Coverage
coverage/
htmlcov/
.coverage

# Python cache (if present)
__pycache__/
*.pyc
*.pyo
*.pyd

# Temporary files
*.tmp
*.temp

# Compressed files
*.zip
*.gz
*.tar
*.tgz
*.bz2
*.xz
*.7z
*.rar
*.zst
*.tar.gz
*.tar.bz2
*.tar.xz
*.tar.zst
```