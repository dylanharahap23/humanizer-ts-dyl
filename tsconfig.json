{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "resolveJsonModule": true,
    "paths": {
      "@/*": ["./*"]
    },
    "types": ["node"]
  },
  "include": ["*.ts"],
  "exclude": ["node_modules"]
}
